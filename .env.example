# ============================================================
# SWIFT E-COMM BACKEND - Environment Variables
# COPY THIS FILE to ".env" (remove .example) and fill in your values
# ============================================================

# Server Port
PORT=5000

# Environment (development or production)
NODE_ENV=development

# MongoDB Database Connection String
# Get this from MongoDB Atlas after creating a free cluster
# Example: mongodb+srv://username:password@cluster.mongodb.net/swiftecomm
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/swiftecomm?retryWrites=true&w=majority

# JWT Secret (for user authentication tokens)
# Generate a random string (32+ characters)
# You can use: https://generate-secret.vercel.app/32
JWT_SECRET=your_super_secret_random_string_here_make_it_long_and_random

# ============================================================
# EMAIL SETTINGS (Gmail)
# ============================================================
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Generate an "App Password" - use that below (NOT your regular Gmail password)

EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your16charactersapppassword

# Where contact form submissions are sent
ADMIN_EMAIL=admin@swiftecomm.com

# ============================================================
# FRONTEND URL
# ============================================================
# During local development:
CLIENT_URL=http://localhost:3000

# When deployed (change this to your GitHub Pages URL):
# CLIENT_URL=https://YOUR_USERNAME.github.io
